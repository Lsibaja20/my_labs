@{
    ViewData["Title"] = "Mi primera vista";
    string autor = "Leo Sibaja";
	int edad = 20;
}
<html>
    <head>
        <title> 
		    @ViewBag.Title
        </title>
    </head>
    <body>
        <div>
            <h1> Modificando una vista </h1>
            <p>
                <strong> Yo soy: </strong> @autor<br />
                Mi edad es <input type="number" value="@edad" placeholder="Escriba su edad" />
            </p>
        </div>
        <div>
            <label>
                Mi carnet es:
            </label>
            <input type="number" placeholder="Escriba su carnet" />
        </div>
    </body>
</html>
